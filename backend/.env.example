# Copy this file to .env and fill in your actual values
# On Render/Railway/Heroku, set these as environment variables in your dashboard

# Gmail App Password for sending OTP emails
# How to get it:
#   1. Go to your Google Account → Security
#   2. Enable 2-Step Verification (if not already)
#   3. Go to Security → App Passwords
#   4. Select "Mail" and "Other (Custom name)" → name it "Event Portal"
#   5. Copy the 16-character password and paste it below
SMTP_PASSWORD=your-16-char-gmail-app-password-here

# Optional: Change the port (default is 5000)
# PORT=5000
